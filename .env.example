# Copy this file to .env and fill it in. Never commit .env.

# Safety switch: true = only log what would be traded, false = trade for real.
DRY_RUN=true

# --- Live trading credentials (only needed when DRY_RUN=false) ---
# Export the private key from your Polymarket wallet (Settings -> Export private key).
PRIVATE_KEY=
# Your Polymarket proxy wallet address (the address shown on your profile,
# where your USDC and positions live).
FUNDER_ADDRESS=
# 1 = email/Magic login (default for most Polymarket accounts)
# 2 = browser wallet (MetaMask) login
# 0 = plain EOA trading directly against the CLOB
SIGNATURE_TYPE=1

# --- Strategy ---
# Fraction of your bankroll used for copying (1.0 = use all of it).
COPY_RATIO=1.0
# Bundle whale portfolios into at most this many chunks.
MAX_CHUNKS=15
# Only copy chunks that are at least this share of the whale portfolio
# (0.05 = a position must be 5% or more of the whale's holdings).
MIN_CHUNK_WEIGHT=0.05
# A chunk already held is kept until it falls below this weight, so it
# doesn't flip-flop around the entry cutoff. Defaults to 0.8 * MIN_CHUNK_WEIGHT.
#EXIT_CHUNK_WEIGHT=0.04
# Minimum order size in USD (Polymarket's own minimum is $1).
MIN_ORDER_USD=1.0
# Only rebalance an existing position when it drifts more than this
# fraction from target. Lower = follows the whale's small adjustments
# more closely; higher = fewer trades and less spread paid.
REBALANCE_BAND=0.05
# FAK = fill what's available, FOK = all-or-nothing.
ORDER_TYPE=FAK

# --- Runtime ---
POLL_SECONDS=60
# Starting cash for paper trading (DRY_RUN=true).
PAPER_BALANCE=20
LOG_LEVEL=INFO
